go.property("interaction_group", 0)

local button = require("Assets.Scripts.button")

function init(self)
	button(go.get_id(), self.interaction_group, go.get_position())
end

function on_message(self, message_id, message, sender)
	if message_id == hash("trigger_response") then
		if message.enter then
			button.interact(self.interaction_group, message.other_id)
		end
	end
end