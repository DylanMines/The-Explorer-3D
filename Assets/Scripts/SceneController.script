local fow = require 'light_and_shadows.fow'
local light = require 'light_and_shadows.light'
local door = require("Assets.Scripts.door")
local button = require("Assets.Scripts.button")
local mtool = require("Assets.Scripts.mtool")
local events = require("event.events")
local color = require("druid.color")
local prompt_object = require("Assets.Scripts.prompt_object")
local prompt = require("Assets.Scripts.prompt")

go.property("fow", resource.texture(""))
go.property("player", msg.url())
go.property("camera_go_id", msg.url())
go.property("Model", msg.url())
go.property("level_changer", msg.url())

local TILE_SIZE = 32
local last_x
local last_y

-- THE LATEST:
--[[
The fog of war stuff only seems to work on the xz plane, which is quite annoying because the camera extension and 2D physics only works on the xy plane. I need to figure out if I can get the fow and 
rest of the light stuff to work on the xy place aswell.

As far as I can tell this does have to do with the normals

]]

local generated_models = {}

local function get_player_position_xy(self)
	local position = go.get_position(self.player) / TILE_SIZE
	return math.ceil(position.x) - self.offset.x + 1, math.ceil(position.y) - self.offset.y + 1
end

local group_tiles = 
{
	[3] = 1,
	[4] = 2,
	[11] = 3,
	[12] = 4,
	[19] = 5,
	[20] = 6,
	[27] = 7,
	[28] = 8
}

local interaction_colors = 
{
	color.hex2vector4("ffadad"),
	color.hex2vector4("bdb2ff"),
	color.hex2vector4("9bf6ff"),
	color.hex2vector4("fdffb6"),
	color.hex2vector4("ffd6a5"),
	color.hex2vector4("caffbf"),
	color.hex2vector4("a0c4ff"),
	color.hex2vector4("ffc6ff")
}

local function get_interaction_group(self, x, y)
	return group_tiles[tilemap.get_tile(self.tileMap, "interaction_number", x, y)]
end

local function get_center_position(self, x, y)
	return vmath.vector3(x * TILE_SIZE, y * TILE_SIZE, 16) - vmath.vector3(TILE_SIZE/2, TILE_SIZE/2, 0)
end

local function set_color(self, id, group)
	local color = interaction_colors[group]
	go.set(id, "tint", color)
end

local function add_door(self, x, y, rot)
	local position = get_center_position(self, x, y)
	local interaction_group_tile = get_interaction_group(self, x, y)
	local ids = collectionfactory.create("#door_factory", position, rot)
	table.insert(generated_models, ids)
	door(ids[hash("/door")],interaction_group_tile, vmath.vector3(x, y, 0)) --[[@as door]]
    set_color(self, msg.url(nil, ids[hash("/model")], "model"), interaction_group_tile)
end

local function add_prompt(self, x, y)
	local position = get_center_position(self, x, y)
	local id = factory.create("#prompt_factory", position)
	prompt_object.object(id, get_interaction_group(self, x, y))
end

local function add_torch(self, x, y, rot)
	local position = get_center_position(self, x, y) + vmath.vector3(0,0,4)
	local ids = collectionfactory.create("#torch_factory", position, rot)
	table.insert(generated_models, ids)
	--go.set(ids["/torch"], "euler.z", rot)
end

local function add_fruit(self, x, y)
	local position = get_center_position(self, x, y)
	local ids = collectionfactory.create("#fruit_factory", position)
	table.insert(generated_models, ids)
end

---@param rot vector4
local function add_button(self, x, y, rot)
	local position = get_center_position(self, x, y) - vmath.vector3(0,0,6)
	props =
	{
		[hash("/button")] = {interaction_group = get_interaction_group(self, x, y)}
	}
	local ids = collectionfactory.create("#button_factory", position, rot, props)
	set_color(self, msg.url(nil, ids[hash("/model")], "model"), get_interaction_group(self, x, y))
	table.insert(generated_models, ids)
end

local function load_level_data(self)
	self.data = loadstring(sys.load_resource("/Levels/"..self.level_name.."/level_data.lua") --[[@as string]])()
end

local function generate_level(self)
	print("generating")

	if self.level_name then
		load_level_data(self)
	end

	if self.data.prompts then
		for index, value in ipairs(self.data.prompts) do
			prompt.prompt(index, value)
		end
	end

	local tx, ty, tw, th = tilemap.get_bounds(self.tileMap)

	self.offset = vmath.vector3(tx, ty, 0)

	fow.init(self, tw, th, TILE_SIZE, self.fow)
	
	tilemap.set_visible(self.tileMap, "interactives", false)
	tilemap.set_visible(self.tileMap, "interaction_number", false)
	tilemap.set_visible(self.tileMap, "spawns", false)
	
	for y = ty, (th + ty - 1) do
        for x = tx, (tw + tx - 1) do
            local v = tilemap.get_tile(self.tileMap, "walls", x, y)
			local f = tilemap.get_tile(self.tileMap, "interactives", x, y)
			local s = tilemap.get_tile(self.tileMap, "spawns", x, y)
            if v == 35 or f == 41 or f == 18 then
                fow.set_b(x - tx + 1, y - ty + 1, 255)
            end
			if f == 17 then
				add_fruit(self, x, y)
			elseif f == 18 then
				add_door(self, x, y, vmath.quat_rotation_z(0))
			elseif f == 41 then
				add_door(self, x, y, vmath.quat_rotation_z(math.pi/2))
			elseif f == 1 then
				add_button(self, x, y, vmath.quat_rotation_z(math.pi/2))
			elseif f == 9 then
				add_button(self, x, y, vmath.quat_rotation_z(0))
			elseif f == 2 then
				add_button(self, x, y, vmath.quat_rotation_z(-(math.pi/2)))
			elseif f == 10 then
				add_button(self, x, y, vmath.quat_rotation_z(math.pi))
			elseif f == 25 then
				add_torch(self, x, y, vmath.quat_rotation_z(math.pi/2))
			elseif f == 33 then
				add_torch(self, x, y, vmath.quat_rotation_z(0))
			elseif f == 26 then
				add_torch(self, x, y, vmath.quat_rotation_z(-(math.pi/2)))
			elseif f == 34 then
				add_torch(self, x, y, vmath.quat_rotation_z(math.pi))
			elseif f == 49 then
				add_prompt(self, x, y)
			end

			if s == 50 then
				self.exit_pos = vmath.vector3(x, y, 0)
			elseif s == 42 then
				print("placing player")
				go.set_position(get_center_position(self, x, y) - vmath.vector3(0, 0, 6), self.player)
			end
        end
    end

	local x, y = get_player_position_xy(self)
    fow.draw(x, y, 10)

	local options = {
		tilemap = self.tileMap,
		layer = "walls", -- Tilemap layer name.
		w = 8, -- Horizontal number of tiles in tileset (texture atlas).
		h = 8, -- Vertical number of tiles in tileset (texture atlas).
		tilesize = 32, -- Size of tile in pixels (it will be use as scale factor when a script generates quads).

		optimize = false, -- If 'true' a script will culling the hidden by neighbors faces (edges 2,3,4,5).
		optimize_back = false -- If 'true' a script will culling back face (6) for all tiles.
	}
    
    self.grid = mtool.create_mesh_from_tilemap(self.Model, options)

end

function init(self)
	self.exit_pos = vmath.vector3()
	self.loaded = false

	events.subscribe("camera_follow", function (self, data)
		print("focusing on",data.target)
		local camera_script = msg.url(nil, self.camera_go_id.path, "script")
		local target = data.target
		local follow_url = self.player
		if target == "player" then
			follow_url = self.player
		elseif string.sub(target, 0, 4) == "door" then
			follow_url = door.get_object_ID(tonumber(string.sub(target, 6)) --[[@as number]])
		elseif string.sub(target, 0, 6) == "button" then
			follow_url = button.get_object_ID(tonumber(string.sub(target, 8)) --[[@as number]])
		end
		go.set(camera_script, "follow_target", follow_url)
	end, self)

	events.subscribe("freeze_player", function (self, freeze)
		print("freezing",freeze)
		local player_script = msg.url(nil, self.player.path, "move")
		go.set(player_script, "frozen", freeze)
	end, self)
end

function final(self)
	fow.final(self)
end

function clear(self)
	print("clearing")
	local player_script = msg.url(nil, self.player.path, "move")
	msg.post(player_script, "drop")
	for _, v in pairs(generated_models) do
		for _, j in pairs(v) do
			go.delete(j, true)
		end
	end
	if self.tileMap then
		go.delete(self.tileMap, false)
	end
	door.clear()
	button.clear()
	prompt.clear()
	prompt_object.clear()
	generated_models = {}
	self.tileMap = nil
	self.level_name = nil
end

function update(self, dt)
	if not self.loaded then return end
	
	local x, y = get_player_position_xy(self)
	if x == self.exit_pos.x and y == self.exit_pos.y then
		msg.post(self.level_changer, "load_next")
		self.exit_pos = vmath.vector3()
		self.loaded = false
	end
	fow.draw(x, y, 7)
	if last_x then
		fow.set_g(last_x, last_y, 0)
	end
	fow.set_g(x, y, 255)
	last_x = x
	last_y = y
	--fow.set_g(x, y, 255)
	if fow.update(self, dt) then
        -- dirty frame. Need to update textures. 
        local res = go.get("minimap#sprite", "texture0")
        -- local res = go.get("/ui#ui",  "textures", {key = "fow"})
        -- print(res)
        fow.set_texture(res)
    end

	light.set_position(go.get_rotation(self.player), go.get_position(self.player), go.get_world_position(self.camera_go_id))
end

function on_message(self, message_id, message, sender)
	if message_id == hash("load") then
		if message.tilemap then 
			self.tileMap = message.tilemap
			self.level_name = message.level_name
			generate_level(self)
			local camera_script = msg.url(nil, self.camera_go_id.path, "script")
			local lerp = go.get(camera_script, "follow_lerp")
			go.set(camera_script, "follow_lerp", 1)
			self.loaded = true
		
			timer.delay(0.1, false, function (self, handle, time_elapsed)
				go.set(camera_script, "follow_lerp", lerp)
				events.trigger("transition", {begin = false})
			end)

			if self.data.name then
				events.trigger("change_location", {name = self.data.name})
			end
		else
			timer.delay(0.1, false, function (self, handle, time_elapsed)
				events.trigger("transition", {begin = false})
			end)
		end
	elseif message_id == hash("unload") then
		self.loaded = false
		clear(self)
	elseif message_id == hash("play_prompt") then

	elseif message_id == hash("focus_target") then
		
	end
end
